{
  "name": "vscode-react-webview-starter",
  "displayName": "vscode-react-webview-starter",
  "description": "",
  "icon": "./assets/otter-icon.png",
  "version": "0.0.1",
  "packageManager": "npm@10.8.2",
  "repository": {
    "url": "https://github.com/OtterDr/OtterDr.git",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.71.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "otterDr.otterView",
          "name": "OtterDr",
          "icon": ".assets/webview.png"
        }
      ]
    },
    "commands": [
      {
        "command": "otterDr.openWebview",
        "title": "Explorer: Open OtterDr View"
      },
      {
        "command": "otterDr.setApiKey",
        "title": "OtterDr: Update API Key"
      },
      {
        "command": "otterDr.deleteApiKey",
        "title": "OtterDr: Delete API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode production --config ./webpack/extension.config.js",
    "watch": "npm-run-all --parallel watch:*",
    "watch:ext": "webpack --mode development --config ./webpack/extension.config.js",
    "watch:wv": "webpack serve --mode development --config ./webpack/webview.config.js",
    "package": "npm run clean && npm-run-all --parallel package:*",
    "package:ext": "webpack --mode production --config ./webpack/extension.config.js",
    "package:wv": "webpack --mode production --config ./webpack/webview.config.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "clean": "rimraf dist",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@estruyf/vscode": "1.1.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "css-loader": "^7.1.4",
    "eslint": "8.57.1",
    "npm-run-all": "4.1.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^4.9.5",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-manifest-plugin": "5.0.0"
  },
  "dependencies": {
    "html-entities": "2.6.0",
    "openai": "6.17.0",
    "vscode": "^1.1.37",
    "vscode-uri": "^3.1.0"
  }
}
